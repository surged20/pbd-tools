<form class="flexcol" autocomplete="off" onsubmit="event.preventDefault();">
    <section class="content">
        {{!-- Section 1: Bot Configuration --}}
        <details class="bot-instructions">
            <summary><strong>{{localize 'pbd-tools.Setting.BotSettings.Instructions.Title'}}</strong></summary>
            <ol>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step1'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step2'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step3'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step4'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step5'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step6'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step7'}}}</li>
            </ol>
        </details>

        <hr>

        <h3>{{localize 'pbd-tools.Setting.BotSettings.SectionConfig'}}</h3>

        <div class="form-group">
            <label for="bot-enabled">{{localize 'pbd-tools.Setting.BotSettings.Enabled.Name'}}</label>
            <div class="form-fields">
                <input type="checkbox" name="bot-enabled" {{checked botEnabled}} />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.Enabled.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="bot-token">{{localize 'pbd-tools.Setting.BotSettings.Token.Name'}}</label>
            <div class="form-fields">
                <input type="password" name="bot-token" value="{{botToken}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.Token.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="bot-proxy-url">{{localize 'pbd-tools.Setting.BotSettings.ProxyUrl.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="bot-proxy-url" value="{{botProxyUrl}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.ProxyUrl.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="rpgsage-app-id">{{localize 'pbd-tools.Setting.BotSettings.RpgSageAppId.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="rpgsage-app-id" value="{{rpgSageAppId}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.RpgSageAppId.Hint'}}</p>
        </div>

        <div class="form-group">
            <button type="button" class="bot-test-connection">
                <i class="fas fa-plug"></i> {{localize 'pbd-tools.Setting.BotSettings.TestConnection'}}
            </button>
        </div>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.BotSettings.GuildName.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="bot-guild-name" value="{{guildName}}" readonly />
                <input type="hidden" name="bot-guild-id" value="{{guildId}}" />
            </div>
        </div>

        <div class="form-group">
            <button type="button" class="bot-discover-channels">
                <i class="fas fa-search"></i> {{localize 'pbd-tools.Setting.BotSettings.DiscoverChannels'}}
            </button>
        </div>

        {{#if discoveredChannels.length}}
        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.BotSettings.AddChannelLabel'}}</label>
            <div class="form-fields" style="display: flex; gap: 0.5rem;">
                <select class="bot-channel-select" style="flex: 2;">
                    <option value="">{{localize 'pbd-tools.Setting.BotSettings.SelectChannel'}}</option>
                    {{#each discoveredChannels}}
                    {{#if this.parentId}}
                    <option value="{{this.id}}">&nbsp;&nbsp;{{this.name}}</option>
                    {{else}}
                    <option value="{{this.id}}">#{{this.name}}</option>
                    {{/if}}
                    {{/each}}
                </select>
                <button type="button" class="bot-add-channel" style="flex: 0 0 auto;">
                    <i class="fas fa-plus"></i>
                </button>
            </div>
        </div>
        {{/if}}

        <hr>

        {{!-- Section 2: Add Manual Channel --}}
        <h3>{{localize 'pbd-tools.Setting.GameChannelSettings.SectionManual'}}</h3>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.DiscordWebhookSettings.ChannelNameLabel'}}</label>
            <div class="form-fields">
                <input type="text" class="webhook-channel-name" placeholder="e.g. IC, OOC, GM..." />
            </div>
        </div>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.DiscordWebhookSettings.WebhookUrlLabel'}}</label>
            <div class="form-fields">
                <input type="text" class="webhook-channel-url" placeholder="https://discord.com/api/webhooks/..." />
            </div>
        </div>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.DiscordWebhookSettings.PersonaName'}}</label>
            <div class="form-fields">
                <input type="text" class="webhook-channel-username" placeholder="PbDT" />
            </div>
        </div>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.DiscordWebhookSettings.PersonaAvatar'}}</label>
            <div class="form-fields">
                <file-picker class="webhook-channel-avatar" type="image" value="icons/vtt-512.png">
            </div>
        </div>

        <div class="form-group">
            <button type="button" class="webhook-add-channel">
                <i class="fas fa-plus"></i> {{localize 'pbd-tools.Setting.DiscordWebhookSettings.AddChannel'}}
            </button>
        </div>

        <hr>

        {{!-- Section 3: Configured Channels --}}
        <h3>{{localize 'pbd-tools.Setting.GameChannelSettings.SectionChannels'}}</h3>

        <div class="channel-list">
            {{#if allChannels.length}}
                {{#each allChannels}}
                <div class="channel-config" style="border: 1px solid var(--color-border-light-tertiary); padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                        <span>
                            <strong>{{#if this.threadName}}#{{this.channelName}} > {{this.threadName}}{{else}}{{this.channelName}}{{/if}}</strong>
                            {{#if this.isBot}}<span class="tag" style="font-size: 0.75em; padding: 0.1em 0.4em; border-radius: 3px; background: var(--color-border-light-tertiary);">{{localize 'pbd-tools.Setting.GameChannelSettings.ModeBadgeBot'}}</span>{{/if}}
                            {{#if this.isManual}}<span class="tag" style="font-size: 0.75em; padding: 0.1em 0.4em; border-radius: 3px; background: var(--color-border-light-tertiary);">{{localize 'pbd-tools.Setting.GameChannelSettings.ModeBadgeManual'}}</span>{{/if}}
                        </span>
                        <span style="display: flex; align-items: center; gap: 0.5rem;">
                            {{#if this.hasWebhook}}
                            <label style="margin: 0; font-weight: normal; white-space: nowrap;" title="{{localize 'pbd-tools.Setting.GameChannelSettings.MenuChannelsHint'}}">
                                <input type="checkbox" name="menu-channel-{{this.targetId}}" {{checked this.isMenuChecked}} />
                                {{localize 'pbd-tools.Setting.GameChannelSettings.ShowInMenus'}}
                            </label>
                            {{/if}}
                            <button type="button" class="remove-channel" data-target-id="{{this.targetId}}" title="{{localize 'pbd-tools.Setting.BotSettings.RemoveChannel'}}">
                                <i class="fas fa-trash"></i>
                            </button>
                        </span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0.25rem;">
                        <label>{{localize 'pbd-tools.Setting.BotSettings.PersonaName'}}</label>
                        <div class="form-fields">
                            <input type="text" name="channel-username-{{this.targetId}}" value="{{this.username}}" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>{{localize 'pbd-tools.Setting.BotSettings.PersonaAvatar'}}</label>
                        <div class="form-fields">
                            <file-picker name="channel-avatar-{{this.targetId}}" type="image" value="{{this.avatar}}">
                        </div>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <p class="notes">{{localize 'pbd-tools.Setting.GameChannelSettings.NoChannels'}}</p>
            {{/if}}
        </div>

        <hr>

        {{!-- Section 4: Action Emojis --}}
        <h3>{{localize 'pbd-tools.Setting.GameChannelSettings.SectionActionEmojis'}}</h3>
        <p class="notes">{{localize 'pbd-tools.Setting.GameChannelSettings.ActionEmojisHint'}}</p>

        {{#each actionEmojis}}
        <div class="form-group">
            <label>{{this.label}}</label>
            <div class="form-fields">
                <input type="text" name="action-emoji-{{this.key}}" value="{{this.value}}" placeholder="<:emoji_name:id>" />
            </div>
        </div>
        {{/each}}

    </section>

    <footer class="sheet-footer buttons">
        <button type="submit" name="submit">
            <i class="far fa-save"></i> {{localize "SETTINGS.Save"}}
        </button>
    </footer>
</form>
