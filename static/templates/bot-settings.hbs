<form class="flexcol" autocomplete="off" onsubmit="event.preventDefault();">
    <section class="content">
        {{!-- Setup Instructions --}}
        <details class="bot-instructions">
            <summary><strong>{{localize 'pbd-tools.Setting.BotSettings.Instructions.Title'}}</strong></summary>
            <ol>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step1'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step2'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step3'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step4'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step5'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step6'}}}</li>
                <li>{{{localize 'pbd-tools.Setting.BotSettings.Instructions.Step7'}}}</li>
            </ol>
        </details>

        <hr>

        {{!-- Bot Configuration --}}
        <h3>{{localize 'pbd-tools.Setting.BotSettings.SectionConfig'}}</h3>

        <div class="form-group">
            <label for="bot-enabled">{{localize 'pbd-tools.Setting.BotSettings.Enabled.Name'}}</label>
            <div class="form-fields">
                <input type="checkbox" name="bot-enabled" {{checked botEnabled}} />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.Enabled.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="bot-token">{{localize 'pbd-tools.Setting.BotSettings.Token.Name'}}</label>
            <div class="form-fields">
                <input type="password" name="bot-token" value="{{botToken}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.Token.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="bot-proxy-url">{{localize 'pbd-tools.Setting.BotSettings.ProxyUrl.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="bot-proxy-url" value="{{botProxyUrl}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.ProxyUrl.Hint'}}</p>
        </div>

        <div class="form-group">
            <label for="rpgsage-app-id">{{localize 'pbd-tools.Setting.BotSettings.RpgSageAppId.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="rpgsage-app-id" value="{{rpgSageAppId}}" />
            </div>
            <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.RpgSageAppId.Hint'}}</p>
        </div>

        <div class="form-group">
            <button type="button" class="bot-test-connection">
                <i class="fas fa-plug"></i> {{localize 'pbd-tools.Setting.BotSettings.TestConnection'}}
            </button>
        </div>

        <hr>

        {{!-- Guild & Discovery --}}
        <h3>{{localize 'pbd-tools.Setting.BotSettings.SectionDiscovery'}}</h3>

        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.BotSettings.GuildName.Name'}}</label>
            <div class="form-fields">
                <input type="text" name="bot-guild-name" value="{{guildName}}" readonly />
                <input type="hidden" name="bot-guild-id" value="{{guildId}}" />
            </div>
        </div>

        <div class="form-group">
            <button type="button" class="bot-discover-channels">
                <i class="fas fa-search"></i> {{localize 'pbd-tools.Setting.BotSettings.DiscoverChannels'}}
            </button>
        </div>

        {{#if discoveredChannels.length}}
        <div class="form-group">
            <label>{{localize 'pbd-tools.Setting.BotSettings.AddChannelLabel'}}</label>
            <div class="form-fields" style="display: flex; gap: 0.5rem;">
                <select class="bot-channel-select" style="flex: 2;">
                    <option value="">{{localize 'pbd-tools.Setting.BotSettings.SelectChannel'}}</option>
                    {{#each discoveredChannels}}
                    <option value="{{this.id}}">#{{this.name}}</option>
                    {{/each}}
                </select>
                <select class="bot-tag-select" style="flex: 1;">
                    {{#each tagChoices}}
                    <option value="{{this.value}}">{{this.label}}</option>
                    {{/each}}
                </select>
                <button type="button" class="bot-add-channel" style="flex: 0 0 auto;">
                    <i class="fas fa-plus"></i>
                </button>
            </div>
        </div>
        {{/if}}

        <hr>

        {{!-- Configured Channels --}}
        <h3>{{localize 'pbd-tools.Setting.BotSettings.SectionChannels'}}</h3>

        <div class="bot-channel-list">
            {{#if gameChannels.length}}
                {{#each gameChannels}}
                <div class="bot-channel-config" style="border: 1px solid var(--color-border-light-tertiary); padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                        <strong>#{{this.channelName}}</strong>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <select name="channel-tag-{{this.channelId}}">
                                <option value="ic" {{#if (eq this.tag "ic")}}selected{{/if}}>IC</option>
                                <option value="ooc" {{#if (eq this.tag "ooc")}}selected{{/if}}>OOC</option>
                                <option value="gm" {{#if (eq this.tag "gm")}}selected{{/if}}>GM</option>
                            </select>
                            <button type="button" class="bot-remove-channel" data-channel-id="{{this.channelId}}" title="{{localize 'pbd-tools.Setting.BotSettings.RemoveChannel'}}">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom: 0.25rem;">
                        <label>{{localize 'pbd-tools.Setting.BotSettings.GmUsername'}}</label>
                        <div class="form-fields">
                            <input type="text" name="channel-username-{{this.channelId}}" value="{{this.gmUsername}}" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>{{localize 'pbd-tools.Setting.BotSettings.GmAvatar'}}</label>
                        <div class="form-fields">
                            <file-picker name="channel-avatar-{{this.channelId}}" type="image" value="{{this.gmAvatar}}">
                        </div>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <p class="notes">{{localize 'pbd-tools.Setting.BotSettings.NoChannelsConfigured'}}</p>
            {{/if}}
        </div>
    </section>

    <footer class="sheet-footer buttons">
        <button type="submit" name="submit">
            <i class="far fa-save"></i> {{localize "SETTINGS.Save"}}
        </button>
    </footer>
</form>
