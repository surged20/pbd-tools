{
  "name": "pbd-tools",
  "version": "0.1.0",
  "description": "Play by Discord Tools for Foundry VTT",
  "main": "index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && vite build",
    "build-old": "npm run && webpack --mode production",
    "build:dev": "npm run && webpack",
    "clean": "rm -rf dist/*",
    "watch": "vite build --watch --mode development",
    "hot": "vite serve",
    "lint": "eslint ./src --ext .ts",
    "lint:fix": "eslint ./src --ext .ts --fix"
